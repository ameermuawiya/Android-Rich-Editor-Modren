<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Container for the video player -->
    <FrameLayout
        android:id="@+id/video_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true">

        <VideoView
            android:id="@+id/are_video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />

    </FrameLayout>

    <!-- Tap Interceptor to Toggle Controls -->
    <View
        android:id="@+id/tap_interceptor"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000" />

    <!-- Center Floating Play/Pause Button -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/btn_center_play"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerInParent="true"
        android:background="#99000000"
        android:clickable="true"
        android:focusable="true"
        android:padding="16dp"
        android:src="@drawable/ic_play"
        android:visibility="visible"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:tint="#FFFFFF" />

    <!-- Intermediate Progress Wheel (Centered) -->
    <ProgressBar
        android:id="@+id/video_loading_indicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_centerInParent="true"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone" />

    <!-- TOP CONTROL BAR -->
    <RelativeLayout
        android:id="@+id/video_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#B3000000"
        android:elevation="6dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/video_btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/video_player_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="sans-serif-medium"
            android:text="Video Player"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/video_btn_info"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/ic_info"
            app:tint="#FFFFFF" />
    </RelativeLayout>

    <!-- CUSTOM PLAYBACK CONTROL PANEL (Glow Overlay Style) -->
    <LinearLayout
        android:id="@+id/playback_control_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/fullscreen_content_controls"
        android:background="#B3000000"
        android:elevation="6dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <!-- Time Scrub & Slider Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="00:00"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />

            <!-- Custom Seekbar styled elegantly -->
            <SeekBar
                android:id="@+id/video_seekbar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="1000"
                android:progress="0"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="00:00"
                android:textColor="#CCCCCC"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Media Control Toolbar Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <!-- Play / Pause left toggle button -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btn_bottom_play"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_play"
                app:tint="#FFFFFF" />

            <!-- Action cluster on the right -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <!-- Aspect Ratio toggle -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/btn_aspect_ratio"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp"
                    android:src="@drawable/ic_aspect_ratio"
                    app:tint="#FFFFFF" />

                <!-- Mute / Unmute Volume toggle -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/btn_volume"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp"
                    android:src="@drawable/ic_volume_up"
                    app:tint="#FFFFFF" />

                <!-- native sharing -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/btn_video_share"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="6dp"
                    android:src="@drawable/ic_share"
                    app:tint="#FFFFFF" />

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

    <!-- Bottom Action Floating Banner Button (Save or Attach) -->
    <LinearLayout
        android:id="@+id/fullscreen_content_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#D0000000"
        android:elevation="8dp"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/are_btn_action"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:fontFamily="sans-serif-medium"
            android:text="Action"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:backgroundTint="#2C2C2C"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_save"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

</RelativeLayout>

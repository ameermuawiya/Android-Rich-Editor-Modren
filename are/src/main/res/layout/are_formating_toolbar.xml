<?xml version="1.0" encoding="utf-8"?>
<merge
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:colorPickerView="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/rteFontSizeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.slider.Slider
            android:id="@+id/are_fontsize_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="12"
            android:valueTo="50"
            android:stepSize="1"
            android:value="18"
            app:labelBehavior="floating" />
    </LinearLayout>

    <com.chinalwb.are.colorpicker.ColorPickerView
        android:id="@+id/rteColorPalette"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:colorViewHeight="32dp"
        app:colorViewWidth="32dp"
        app:colorViewCheckedType="checkMark"
        app:colors="@array/colorPickerColors" />

    <HorizontalScrollView
        android:id="@+id/FormatingToolsBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteBold"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_bold"
                android:contentDescription="@string/are_editor_desc_bold"
                app:tooltipText="@string/are_editor_desc_bold"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteItalic"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_italic"
                android:contentDescription="@string/are_editor_desc_italic"
                app:tooltipText="@string/are_editor_desc_italic"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteUnderline"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_underline"
                android:contentDescription="@string/are_editor_desc_underline"
                app:tooltipText="@string/are_editor_desc_underline"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteStrikethrough"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_strikethrough"
                android:contentDescription="@string/are_editor_desc_strikethrough"
                app:tooltipText="@string/are_editor_desc_strikethrough"
                android:checkable="true" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteFontsize"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_size"
                android:contentDescription="@string/are_editor_desc_font_size"
                app:tooltipText="@string/are_editor_desc_font_size"
                android:checkable="true"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteFontColor"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_color_text"
                android:contentDescription="@string/are_editor_desc_font_color"
                app:tooltipText="@string/are_editor_desc_font_color"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteBackground"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_brush"
                android:contentDescription="@string/are_editor_desc_background_color"
                app:tooltipText="@string/are_editor_desc_background_color"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteFontface"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_font"
                android:contentDescription="@string/are_editor_desc_font_face"
                app:tooltipText="@string/are_editor_desc_font_face"
                android:checkable="true"
                android:visibility="gone" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteAlignLeft"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_align_left"
                android:contentDescription="@string/are_editor_desc_align_left"
                app:tooltipText="@string/are_editor_desc_align_left"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteAlignCenter"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_align_center"
                android:contentDescription="@string/are_editor_desc_align_center"
                app:tooltipText="@string/are_editor_desc_align_center"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteAlignRight"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_align_right"
                android:contentDescription="@string/are_editor_desc_align_right"
                app:tooltipText="@string/are_editor_desc_align_right"
                android:checkable="true" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteListBullet"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_list_bulleted"
                android:contentDescription="@string/are_editor_desc_list_bullet"
                app:tooltipText="@string/are_editor_desc_list_bullet"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteListNumber"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_list_numbered"
                android:contentDescription="@string/are_editor_desc_list_number"
                app:tooltipText="@string/are_editor_desc_list_number"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteIndentRight"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_indent_increase"
                android:contentDescription="@string/are_editor_desc_indent_increase"
                app:tooltipText="@string/are_editor_desc_indent_increase"
                android:checkable="true"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteIndentLeft"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_indent_decrease"
                android:contentDescription="@string/are_editor_desc_indent_decrease"
                app:tooltipText="@string/are_editor_desc_indent_decrease"
                android:checkable="true"
                android:visibility="gone" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteInsertImage"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_image"
                android:contentDescription="@string/are_editor_desc_insert_image"
                app:tooltipText="@string/are_editor_desc_insert_image"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteInsertVideo"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_video"
                android:contentDescription="@string/are_editor_desc_insert_video"
                app:tooltipText="@string/are_editor_desc_insert_video"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteLink"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_insert_link"
                android:contentDescription="@string/are_editor_desc_insert_link"
                app:tooltipText="@string/are_editor_desc_insert_link"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteAt"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_at"
                android:contentDescription="@string/are_editor_desc_mention"
                app:tooltipText="@string/are_editor_desc_mention"
                android:checkable="true"
                android:visibility="gone" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteQuote"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_quote"
                android:contentDescription="@string/are_editor_desc_quote"
                app:tooltipText="@string/are_editor_desc_quote"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteHr"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_horizontal_rule"
                android:contentDescription="@string/are_editor_desc_horizontal_rule"
                app:tooltipText="@string/are_editor_desc_horizontal_rule"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteSubscript"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_subscript"
                android:contentDescription="@string/are_editor_desc_subscript"
                app:tooltipText="@string/are_editor_desc_subscript"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteSuperscript"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_superscript"
                android:contentDescription="@string/are_editor_desc_superscript"
                app:tooltipText="@string/are_editor_desc_superscript"
                android:checkable="true" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginHorizontal="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteClearFormat"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_action_clear"
                android:contentDescription="@string/are_editor_desc_clear_format"
                app:tooltipText="@string/are_editor_desc_clear_format"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteShowSource"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_action_source"
                android:contentDescription="@string/are_editor_desc_show_source"
                app:tooltipText="@string/are_editor_desc_show_source"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/rteUpDown"
                style="?attr/materialIconButtonFilledTonalStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_action_upward"
                android:contentDescription="@string/are_editor_desc_toggle_toolbar"
                app:tooltipText="@string/are_editor_desc_toggle_toolbar"
                android:visibility="visible" />

        </LinearLayout>
    </HorizontalScrollView>
</merge>

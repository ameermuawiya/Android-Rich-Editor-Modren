<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="ColorPickerView">
        <attr
            name="colorViewWidth"
            format="dimension" />
        <attr
            name="colorViewHeight"
            format="dimension" />
        <attr
            name="colorViewMarginLeft"
            format="dimension" />
        <attr
            name="colorViewMarginRight"
            format="dimension" />
        <attr
            name="colorViewCheckedType"
            format="enum">
            <enum
                name="dot"
                value="0" />
            <enum
                name="checkMark"
                value="1" />
        </attr>
        <attr
            name="colors"
            format="reference" />
    </declare-styleable>

    <declare-styleable name="are">
        <attr
            name="hideToolbar"
            format="boolean" />
        <attr
            name="toolbarAlignment"
            format="enum">
            <enum
                name="BOTTOM"
                value="0" />
            <enum
                name="TOP"
                value="1" />
        </attr>

        <attr
            name="toolbarBackgroundColor"
            format="color|reference" />
    </declare-styleable>

    <declare-styleable name="AreTextView">
        <attr name="zoomEnabled" format="boolean" />
        <attr name="minZoom" format="float" />
        <attr name="maxZoom" format="float" />
    </declare-styleable>

    <attr
        name="colorPrimary"
        format="color" />
    <attr
        name="colorOnPrimary"
        format="color" />
    <attr
        name="colorPrimaryContainer"
        format="color" />
    <attr
        name="colorOnPrimaryContainer"
        format="color" />

    <attr
        name="colorSecondary"
        format="color" />
    <attr
        name="colorOnSecondary"
        format="color" />
    <attr
        name="colorSecondaryContainer"
        format="color" />
    <attr
        name="colorOnSecondaryContainer"
        format="color" />

    <attr
        name="colorTertiary"
        format="color" />
    <attr
        name="colorOnTertiary"
        format="color" />
    <attr
        name="colorTertiaryContainer"
        format="color" />
    <attr
        name="colorOnTertiaryContainer"
        format="color" />

    <attr
        name="colorSurface"
        format="color" />
    <attr
        name="colorOnSurface"
        format="color" />
    <attr
        name="colorSurfaceVariant"
        format="color" />
    <attr
        name="colorOnSurfaceVariant"
        format="color" />
    <attr
        name="colorSurfaceTint"
        format="color" />

    <attr
        name="colorBackground"
        format="color" />
    <attr
        name="colorOnBackground"
        format="color" />

    <attr
        name="colorError"
        format="color" />
    <attr
        name="colorOnError"
        format="color" />
    <attr
        name="colorErrorContainer"
        format="color" />
    <attr
        name="colorOnErrorContainer"
        format="color" />

    <attr
        name="colorOutline"
        format="color" />
    <attr
        name="colorOutlineVariant"
        format="color" />

    <attr
        name="colorInverseSurface"
        format="color" />
    <attr
        name="colorInverseOnSurface"
        format="color" />
    <attr
        name="colorInversePrimary"
        format="color" />

    <attr
        name="colorSurfaceDim"
        format="color" />
    <attr
        name="colorSurfaceBright"
        format="color" />
    <attr
        name="colorSurfaceContainerLowest"
        format="color" />
    <attr
        name="colorSurfaceContainerLow"
        format="color" />
    <attr
        name="colorSurfaceContainer"
        format="color" />
    <attr
        name="colorSurfaceContainerHigh"
        format="color" />
    <attr
        name="colorSurfaceContainerHighest"
        format="color" />

    <attr
        name="colorPrimaryFixed"
        format="color" />
    <attr
        name="colorPrimaryFixedDim"
        format="color" />
    <attr
        name="colorOnPrimaryFixed"
        format="color" />
    <attr
        name="colorOnPrimaryFixedVariant"
        format="color" />

    <attr
        name="colorSecondaryFixed"
        format="color" />
    <attr
        name="colorSecondaryFixedDim"
        format="color" />
    <attr
        name="colorOnSecondaryFixed"
        format="color" />
    <attr
        name="colorOnSecondaryFixedVariant"
        format="color" />

    <attr
        name="colorTertiaryFixed"
        format="color" />
    <attr
        name="colorTertiaryFixedDim"
        format="color" />
    <attr
        name="colorOnTertiaryFixed"
        format="color" />
    <attr
        name="colorOnTertiaryFixedVariant"
        format="color" />

</resources>
